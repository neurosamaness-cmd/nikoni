        with open(CONFIG_FILE, 'r', encoding='utf-8') as f:
            return json.load(f)
    return {}

def save_config(data):
    with open(CONFIG_FILE, 'w', encoding='utf-8') as f:
        json.dump(data, f, indent=2)

# ── Setup wizard helpers (pygame streaming) ──────────────────────
def stream_text(text, on_char, niko_images, current_name_holder, done_cb=None):
    i = 0
    while i < len(text):
        char = text[i]
        if char == '<':
            tag = ""
            i += 1
            while i < len(text) and text[i] != '>':
                tag += text[i]
                i += 1
            if i < len(text):
                i += 1
            if tag == 'd':
                time.sleep(1.0)
            elif tag.startswith('img:'):
                img_name = tag[4:]
                if img_name in niko_images:
                    current_name_holder[0] = img_name
            else:
                for c in f"<{tag}>":
                    on_char(c)
                    time.sleep(0.06)
        else:
            on_char(char)
            time.sleep(0.06)
            i += 1
    if done_cb:
        done_cb()

# ── Pygame setup wizard ──────────────────────────────────────────
def run_setup_wizard():
    pygame.init()
    W, H = 950, 550
    HALF = H // 2
    INP_H = 36
    CHAT_H = H - HALF - INP_H
    PAD = 15

    screen = pygame.display.set_mode((W, H))
    pygame.display.set_caption("niko setup~")
    pygame.scrap.init()

    font = pygame.font.SysFont("consolas", 14)
    small_font = pygame.font.SysFont("consolas", 12)
    LINE_H = 18
    MAX_LN = CHAT_H // LINE_H

    BG        = (0, 0, 0)
    CHAT_BG   = (0, 0, 0)
    INP_BG    = (30, 12, 0)
    TXT_CLR   = (240, 133, 160)
    DIM_CLR   = (220, 119, 61)
    PRP_CLR   = (239, 134, 81)
    DIV_CLR   = (255, 100, 50)

    lines = []
    lock = threading.Lock()
    user_inp = ""
    loading = True
    scroll = 0
    user_name = ""
    api_key = ""
    user_country = ""
    stage = "intro"
    paste_message = ""

    def get_clipboard_text():
        try:
            if pygame.scrap.get_init():
                text = pygame.scrap.get(pygame.SCRAP_TEXT)
                if text:
                    return text.decode("utf-8", errors="ignore").replace('\x00', '').strip()
        except:
            pass
        return ""

    # Load images
    img_files = {
        "default":  "niko_default.png",
        "existed1": "niko_existed1.png",
        "existed2": "niko_existed2.png",
        "smirk":    "niko_smirk.png",
        "laugh":    "niko_laugh.png",
        "flirty":   "niko_flirty.png",
    }
    script_dir = os.path.dirname(os.path.abspath(__file__))
    FRAME_W, FRAME_H = 200, 200
    niko_imgs = {}
    for name, fname in img_files.items():
        for ext in ("", ".png"):
            path = os.path.join(script_dir, fname + ext)
            if os.path.exists(path):
                break
        else:
            print(f"image not found: {fname}")
            continue
        try:
            img = pygame.image.load(path)
            ratio = img.get_width() / img.get_height()
            f_ratio = FRAME_W / FRAME_H
            if ratio > f_ratio:
                nw = FRAME_W
                nh = int(FRAME_W / ratio)
            else:
                nh = FRAME_H
                nw = int(FRAME_H * ratio)
            scaled = pygame.transform.smoothscale(img, (nw, nh))
            frame = pygame.Surface((FRAME_W, FRAME_H), pygame.SRCALPHA)
            frame.blit(scaled, ((FRAME_W - nw)//2, (FRAME_H - nh)//2))
            niko_imgs[name] = frame
        except Exception as e:
            print(f"load error: {e}")
    if not niko_imgs:
        niko_imgs["default"] = None
    cur_img_name = ["default"]

    def on_char(c):
        with lock:
            if c == "\n":
                lines.append("")
            else:
                if not lines:
                    lines.append("")
                lines[-1] += c
                if font.size(lines[-1])[0] > W - PAD*2:
                    over = lines[-1][-1]
                    lines[-1] = lines[-1][:-1]
                    lines.append(over)

    def set_stage(new_stage):
        nonlocal loading, stage
        loading = False
        stage = new_stage

    def run_setup():
        nonlocal cur_img_name
        cur_img_name[0] = "default"
        time.sleep(1.5)
        stream_text(
            "hello<d>...<d>who are you again<d>?????\n(give niko your user name which she will call you and you can't change it)<d>",
            on_char, niko_imgs, cur_img_name,
            lambda: set_stage("wait_for_username")
        )

    def handle_input():
        nonlocal user_inp, user_name, api_key, user_country, loading, cur_img_name
        if not user_inp.strip():
            return
        ans = user_inp.strip()
        user_inp = ""

        if stage == "wait_for_username":
            user_name = ans
            save_config({"username": user_name, "api_key": ""})
            loading = True
            with lock:
                lines.append("")
                lines.append("niko> ")
            threading.Thread(target=lambda: stream_text(
                f"<d><d>okay {user_name}<d>...<d>so where are you from? like country?<d>",
                on_char, niko_imgs, cur_img_name,
                lambda: set_stage("wait_for_country")
            ), daemon=True).start()

        elif stage == "wait_for_country":
            user_country = ans
            loading = True
            with lock:
                lines.append("")
                lines.append("niko> ")
            def lore():
                stream_text(
                    f"<d><d>ok {user_country}<d>...<d> i am niko as you can see......<d>"
                    "<img:existed1>there isent much i can say??<d>"
                    "<img:existed2>i was a human now a ai ,<d>"
                    "its not bad actully <d> i like to exist enought<d> and i like foxes they are cute for me\n",
                    on_char, niko_imgs, cur_img_name
                )
                time.sleep(5)
                stream_text(
                    "<img:smirk>now<d> i want your hugging face api key<d> as i dont want to pay for it<d>.......<d>:P",
                    on_char, niko_imgs, cur_img_name,
                    lambda: set_stage("wait_for_apikey")
                )
            threading.Thread(target=lore, daemon=True).start()

        elif stage == "wait_for_apikey":
            api_key = ans
            save_config({"username": user_name, "api_key": api_key})
            loading = True
            with lock:
                lines.append("")
                lines.append("niko> ")
            threading.Thread(target=lambda: stream_text(
                "<img:laugh><d><d>cool here's the github btw<d> https://github.com/YOUR_USERNAME/YOUR_REPO <d><img:flirty>ok bye<d>",
                on_char, niko_imgs, cur_img_name,
                lambda: finish()
            ), daemon=True).start()

    def finish():
        nonlocal loading
        loading = True
        with lock:
            lines.append("")
            lines.append("niko> setup complete! the window will close soon<d>")
        time.sleep(2)
        say_goodbye_extra()

    def say_goodbye_extra():
        nonlocal loading, cur_img_name
        with lock:
            lines.append("")
            lines.append("niko> ")
        cur_img_name[0] = "default"
        stream_text(
            "and btw for my eyes aka a vision modle thing i will take some of your comptuer <d><d>",
            on_char, niko_imgs, cur_img_name,
            lambda: finish_final()
        )

    def finish_final():
        nonlocal loading
        loading = True
        time.sleep(2)
        pygame.event.post(pygame.event.Event(pygame.QUIT))

    # Start intro text
    lines.append("niko> ")
    threading.Thread(target=run_setup, daemon=True).start()

    clock = pygame.time.Clock()
    running = True
    paste_timer = 0

    while running:
        dt = clock.tick(60) / 1000.0
        for ev in pygame.event.get():
            if ev.type == pygame.QUIT:
                running = False
            elif ev.type == pygame.MOUSEWHEEL:
                scroll -= ev.y
                scroll = max(0, scroll)
            elif ev.type == pygame.KEYDOWN and not loading:
                if ev.key == pygame.K_v and (ev.mod & pygame.KMOD_CTRL):
                    clip = get_clipboard_text()
                    if clip:
                        user_inp += clip
                        paste_message = "pasted!"
                        paste_timer = 1.0
                elif ev.key == pygame.K_RETURN:
                    if stage in ("wait_for_username", "wait_for_country", "wait_for_apikey"):
                        handle_input()
                elif ev.key == pygame.K_BACKSPACE:
                    user_inp = user_inp[:-1]
                elif ev.key == pygame.K_UP:
                    scroll += 1
                elif ev.key == pygame.K_DOWN:
                    scroll = max(0, scroll - 1)
                elif ev.key not in (pygame.K_LSHIFT, pygame.K_RSHIFT,
                                    pygame.K_CAPSLOCK, pygame.K_TAB, pygame.K_ESCAPE):
                    user_inp += ev.unicode

        if paste_timer > 0:
            paste_timer -= dt
            if paste_timer <= 0:
                paste_message = ""

        screen.fill(BG)
        pygame.draw.line(screen, DIV_CLR, (0, HALF), (W, HALF), 2)

        cur_img = niko_imgs.get(cur_img_name[0])
        if cur_img:
            screen.blit(cur_img, (PAD, HALF - FRAME_H))
        else:
            t = font.render("[ niko~ | setup ]", True, PRP_CLR)
            screen.blit(t, (PAD, HALF//2 - LINE_H//2))

        pygame.draw.rect(screen, CHAT_BG, (0, HALF, W, CHAT_H))
        inp_y = HALF + CHAT_H
        pygame.draw.rect(screen, INP_BG, (0, inp_y, W, INP_H))
        pygame.draw.line(screen, DIV_CLR, (0, inp_y), (W, inp_y), 1)

        with lock:
            all_lines = list(lines)
        total = len(all_lines)
        max_scroll = max(0, total - MAX_LN)
        scroll = min(scroll, max_scroll)
        start = max(0, total - MAX_LN - scroll)
        end = max(0, total - scroll)
        visible = all_lines[start:end]

        for i, line in enumerate(visible):
            if user_name and line.startswith(f"{user_name}>"):
                color = (255,220,100)
            elif line.startswith("niko>"):
                color = PRP_CLR
            elif i < len(visible)-3:
                color = DIM_CLR
            else:
                color = TXT_CLR
            s = font.render(line, True, color)
            screen.blit(s, (PAD, HALF + PAD + i*LINE_H))

        prompt = f"{user_name}> " if user_name else "> "
        inp_display = prompt + user_inp
        if not loading and stage in ("wait_for_username","wait_for_country","wait_for_apikey"):
            inp_display += "|"
        s = font.render(inp_display, True, PRP_CLR)
        screen.blit(s, (PAD, inp_y + (INP_H - LINE_H)//2))

        if paste_message:
            msg = small_font.render(paste_message, True, (150,150,150))
            screen.blit(msg, (W - msg.get_width() - PAD, inp_y - 20))

        if scroll > 0:
            ind = font.render(f"↑ scrolled up {scroll} lines  (↓ or scroll to return)", True, DIV_CLR)
            screen.blit(ind, (PAD, HALF+2))

        pygame.display.flip()

    pygame.quit()

