def ensure_files_exist():
    os.makedirs(CONVOS_DIR, exist_ok=True)
    if not os.path.exists(USER_FILE):
        with open(USER_FILE, "w", encoding="utf-8") as f:
            f.write(f"User: {USERNAME}\n")
    if not os.path.exists(LIFE_FILE):
        with open(LIFE_FILE, "w", encoding="utf-8") as f:
            f.write("")
    if not os.path.exists(JOKES_FILE):
        with open(JOKES_FILE, "w", encoding="utf-8") as f:
            json.dump(DEFAULT_JOKES, f, indent=2)
    if not os.path.exists(NIKO_JSON_FILE):
        with open(NIKO_JSON_FILE, "w", encoding="utf-8") as f:
            json.dump({"total_conversations": 0, "entries": []}, f, indent=2)

def get_time():
    return datetime.now().strftime("%H:%M")

def get_weather():
    try:
        res = requests.get("https://wttr.in/India?format=%C")
        return res.text.strip().lower()
    except:
        return "unknown"

def screeno():
    return "watching minecraft videos"

def read_user_file():
    if not os.path.exists(USER_FILE):
        return ""
    with open(USER_FILE, "r", encoding="utf-8") as f:
        return f.read()

def read_niko_file():
    if not os.path.exists(NIKO_JSON_FILE):
        return json.dumps({"total_conversations": 0, "entries": []})
    with open(NIKO_JSON_FILE, "r", encoding="utf-8") as f:
        return f.read()

def read_life_snippet(lines=5):
    if not os.path.exists(LIFE_FILE):
        return ""
    with open(LIFE_FILE, "r", encoding="utf-8") as f:
        all_lines = f.readlines()
    return "".join(all_lines[-lines:]) if all_lines else ""

def load_jokes(max_usage=2):
    if not os.path.exists(JOKES_FILE):
        return []
    with open(JOKES_FILE, "r", encoding="utf-8") as f:
        jokes = json.load(f)
    return [j for j in jokes if j.get("used", 0) < max_usage]

def update_jokes_usage(used_ids):
    if not os.path.exists(JOKES_FILE):
        return
    with open(JOKES_FILE, "r", encoding="utf-8") as f:
        jokes = json.load(f)
    for joke in jokes:
        if joke["id"] in used_ids:
            joke["used"] = joke.get("used", 0) + 1
    with open(JOKES_FILE, "w", encoding="utf-8") as f:
        json.dump(jokes, f, indent=2)

def save_conversation(full_convo, timestamp_str):
    filename = f"{timestamp_str}.txt"
    path = os.path.join(CONVOS_DIR, filename)
    with open(path, "w", encoding="utf-8") as f:
        json.dump(full_convo, f, ensure_ascii=False, indent=2)

def update_niko_file(diary_entry, mood_token="neutral"):
    if os.path.exists(NIKO_JSON_FILE):
        with open(NIKO_JSON_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
    else:
        data = {"total_conversations": 0, "entries": []}
    data["total_conversations"] += 1
    entry = {
        "date": datetime.now().strftime("%Y-%m-%d %H:%M"),
        "summary": diary_entry.strip() if diary_entry else "",
        "mood": mood_token
    }
    data["entries"].append(entry)
    if len(data["entries"]) > 50:
        data["entries"] = data["entries"][-50:]
    with open(NIKO_JSON_FILE, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)

