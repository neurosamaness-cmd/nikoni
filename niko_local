        "api_key": api_key,
        "username": username,
        "history": []
    })
    data = res.json()
    SESSION_ID = data["session_id"]
    print(f"\n[niko] session ready")
    print(f"[niko] paste this into the ui:\n  {SESSION_ID}")
    return SESSION_ID

def calculate_new_mood(last_mood, time_str, weather, activity):
    hour = int(time_str.split(":")[0])
    if 5 <= hour < 12: time_mood, time_energy = "playful", 0.8
    elif 12 <= hour < 17: time_mood, time_energy = "sassy", 0.9
    elif 17 <= hour < 22: time_mood, time_energy = "chill", 0.6
    else: time_mood, time_energy = "sleepy", 0.3
    if "rain" in weather or "drizzle" in weather: time_energy -= 0.2; time_mood = "chill"
    elif "sunny" in weather or "clear" in weather: time_energy += 0.1
    if activity == "coding": time_energy += 0.1
    elif activity == "gaming": time_energy += 0.2
    elif activity == "idle": time_energy -= 0.2
    energy = max(0.1, min(1.0, time_energy))
    if last_mood:
        prev_energy = last_mood.get("energy", 0.5)
        energy = (energy * 0.7) + (prev_energy * 0.3)
        mood = last_mood.get("mood", time_mood) if abs(energy - prev_energy) < 0.15 else time_mood
    else:
        mood = time_mood
    char_delay = int(60 - (energy * 30))
    sass_map = {"sassy": 0.9, "playful": 0.7, "chill": 0.4, "sleepy": 0.2}
    return {"mood": mood, "energy": round(energy,2), "char_delay": char_delay, "sass_level": sass_map.get(mood,0.5), "weather": weather, "time": time_str, "activity": activity}

def emotion_tick(session_id, mood):
    payload = {"session_id": session_id, "time": mood["time"], "timezone": TIMEZONE, "weather": mood["weather"], "activity_summary": mood["activity"], "emotion": mood}
    try: requests.post(f"{SERVER}/emotion_update", json=payload)
    except: pass

def wake_event(session_id, mood):
    screen = screeno()
    payload = {"session_id": session_id, "screen_context": screen, "emotion_snapshot": f"{mood['mood']} + energy {mood['energy']}", "last_activity": mood["activity"]}
    try: requests.post(f"{SERVER}/wake_event", json=payload)
    except: pass

def upload_memory(session_id):
    ensure_files_exist()
    user_data = read_user_file()
    niko_data = read_niko_file()
    life_snippet = read_life_snippet(5)
    jokes = load_jokes()
    payload = {
        "session_id": session_id,
        "user_file": user_data,
        "niko_file": niko_data,
        "life_line": read_life_snippet(5),
        "life_file_snippet": life_snippet,
        "jokes": jokes
    }
    try:
        res = requests.post(f"{SERVER}/memory_load", json=payload)
        print(f"[memory] uploaded ({len(jokes)} jokes)")
    except Exception as e:
        print(f"[memory] upload failed: {e}")

def poll_memory_updates(session_id):
    print("[memory poll] started")
    while True:
        try:
            res = requests.get(f"{SERVER}/memory_pending/{session_id}")
            data = res.json()
            if data.get("action") == "save_memory":
                update = data["data"]
                ts = datetime.now().strftime("%Y-%m-%d_%H-%M")
                if update.get("full_convo"):
                    save_conversation(update["full_convo"], ts)
                update_niko_file(update.get("diary_entry", ""))
                append_to_life(update.get("convo_summary", ""))
                new_user = update.get("new_user_file", "")
                if new_user and new_user.strip().lower() != "null":
                    with open(USER_FILE, "w", encoding="utf-8") as f:
                        f.write(new_user.strip() + "\n")
                    print("[memory] user file replaced")
                else:
                    append_to_user_file(update.get("user_update", ""))
                used_ids = update.get("used_joke_ids", [])
                if used_ids:
                    update_jokes_usage(used_ids)
                print("[memory] session saved.")
        except:
            pass
        time.sleep(3)

def poll_server(session_id):
    global last_mood
    print("[agent] listening for pings...")
    while True:
        try:
            res = requests.get(f"{SERVER}/pending/{session_id}")
            data = res.json()
            if data.get("action") == "screenshot":
                print("[agent] ping received!")
                screen = screeno()
                time_str, weather = get_time(), get_weather()
                mood = calculate_new_mood(last_mood, time_str, weather, current_activity)
                last_mood = mood
                emotion_tick(session_id, mood)
                wake_event(session_id, mood)
        except:
            pass
        time.sleep(2)

def manual_commands(session_id):
    global current_activity, last_mood
    print("\ncommands: tick | wake | screeno | coding | gaming | discord | idle | mood | memory | rerun\n")
    while True:
        cmd = input().strip().lower()
        if cmd == "tick":
            time_str, weather = get_time(), get_weather()
            last_mood = calculate_new_mood(last_mood, time_str, weather, current_activity)
            emotion_tick(session_id, last_mood)
        elif cmd == "wake":
            if not last_mood:
                time_str, weather = get_time(), get_weather()
                last_mood = calculate_new_mood(None, time_str, weather, current_activity)
            wake_event(session_id, last_mood)
        elif cmd == "screeno":
            print(f"screeno: '{screeno()}'")
        elif cmd in ("coding", "gaming", "discord", "idle"):
            current_activity = cmd
            print(f"activity: {current_activity}")
        elif cmd == "mood":
            if last_mood:
                print(f"{last_mood['mood']} | energy: {last_mood['energy']} | sass: {last_mood['sass_level']}")
            else:
                print("no mood yet")
        elif cmd == "memory":
            upload_memory(session_id)
        elif cmd == "rerun":
            print("[agent] deleting config and restarting...")
            if os.path.exists(CONFIG_FILE):
                os.remove(CONFIG_FILE)
            os.execv(sys.executable, ['python'] + sys.argv)
        else:
            print("unknown cmd")

def wait_for_frontend(session_id):
    print("[agent] waiting for frontend...")
    while True:
        try:
            res = requests.get(f"{SERVER}/connected/{session_id}")
            if res.json().get("connected"):
                return
        except:
            pass
        time.sleep(3)

def run_agent(config):
    global USERNAME, current_activity, last_mood
    USERNAME = config["username"]
    api_key = config["api_key"]
    last_mood = None
    ensure_files_exist()
    sid = start_session(api_key, USERNAME)
    threading.Thread(target=manual_commands, args=(sid,), daemon=True).start()
    wait_for_frontend(sid)
    print("[agent] frontend connected. uploading memory...")
    upload_memory(sid)
    threading.Thread(target=poll_server, args=(sid,), daemon=True).start()
    threading.Thread(target=poll_memory_updates, args=(sid,), daemon=True).start()
    while True:
        time.sleep(60)

# ── LAUNCHER ──────────────────────────────────────────────────────
if __name__ == "__main__":
    config = load_config()
    if config.get("username") and config.get("api_key"):
        print("[launcher] config found, starting agent...")
        run_agent(config)
    else:
        print("[launcher] no config found, running setup wizard...")
        run_setup_wizard()
        config = load_config()
        if config.get("username") and config.get("api_key"):
            print("[launcher] setup complete, launching agent...")
            run_agent(config)
        else:
            print("[launcher] setup incomplete, exiting.")
